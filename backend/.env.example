NODE_ENV=development
PORT=8080
APP_NAME=HostMaster Panel
APP_URL=http://localhost:8080
API_PREFIX=/api
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hostmaster?schema=public
REDIS_URL=redis://localhost:6379
AGENT_URL=http://localhost:9090
AGENT_TOKEN=change-me-hostmaster-agent-secret-change-me
AGENT_TIMEOUT_MS=10000
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=1
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
ADMIN_BOOTSTRAP_EMAIL=admin@hostmaster.local
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe123!
ADMIN_BOOTSTRAP_USERNAME=admin
DEFAULT_LOCALE=en
DEFAULT_THEME=dark
MOCK_SYSTEM_MODE=true
