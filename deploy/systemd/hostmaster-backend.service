[Unit]
Description=HostMaster Backend API
After=network.target postgresql.service redis.service

[Service]
Type=simple
User=hostmaster
Group=hostmaster
WorkingDirectory=/opt/hostmaster/backend
EnvironmentFile=/opt/hostmaster/backend/.env
ExecStart=/usr/bin/node /opt/hostmaster/backend/dist/index.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
